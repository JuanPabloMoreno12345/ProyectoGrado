<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
  <record id="demo_user_admin" model="res.users">
    <field name="name">Demo Owner</field>
    <field name="login">demo_owner</field>
  </record>

  <record id="demo_rock_1" model="eos.rock">
    <field name="name">Aumentar ingresos 35% respecto Q3 2025</field>
    <field name="description">Roca estratégica para priorizar ventas y expansión</field>
    <field name="owner_id" ref="demo_user_admin"/>
    <field name="due_date">2025-12-31</field>
    <field name="status">in_progress</field>
  </record>

  <record id="demo_kr_1" model="eos.key_result">
    <field name="name">Contratos firmados</field>
    <field name="rock_id" ref="demo_rock_1"/>
    <field name="target_value">3.0</field>
    <field name="current_value">3.0</field>
    <field name="weight">1.0</field>
  </record>

  <record id="demo_kr_2" model="eos.key_result">
    <field name="name">Ingresos pipeline (EUR)</field>
    <field name="rock_id" ref="demo_rock_1"/>
    <field name="target_value">150000.0</field>
    <field name="current_value">120000.0</field>
    <field name="weight">1.0</field>
  </record>

  <record id="demo_todo_1" model="eos.todo">
    <field name="name">Contacto con Cliente Alpha</field>
    <field name="assigned_to" ref="demo_user_admin"/>
    <field name="due_date">2025-10-20</field>
    <field name="rock_id" ref="demo_rock_1"/>
  </record>

</odoo>
