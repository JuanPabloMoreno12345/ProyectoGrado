<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
  <t t-name="mi90_eos.Dashboard">
    <div class="mi90--wrap" t-ref="root">
      <div class="mi90--header">
        <h1>EOS DATA</h1>
          <!-- Navigation buttons removed per request -->
        <div class="mi90--legend">
          <span class="dot dot-lav"></span> Lavanda
          <span class="dot dot-cel"></span> Celeste
          <span class="dot dot-ros"></span> Rosa
        </div>
      </div>

      

      <div class="mi90--grid">
        <!-- Scorecard ancho (ocupa 2 columnas) -->
        <div class="mi90--card mi90--scorecard">
          <t t-call="mi90_eos.Scorecard"/>
        </div>

        <!-- Analytics en la columna central (reemplaza To-Do) -->
        <div class="mi90--card mi90--analytics">
          <h2>Analítica de Issues y Objetivos</h2>
          <div class="analytics--row">
            <div class="analytics--chart card-issues-priority">
              <div class="chart--title">Issues por prioridad</div>
              <div class="chart--wrap">
                <div class="pie pie-issues-priority" aria-label="Issues por prioridad"></div>
                <ul class="chart--legend">
                  <li><span class="dot dot-red"></span> Alta: <span class="issues-prio-high">0</span></li>
                  <li><span class="dot dot-blue"></span> Media: <span class="issues-prio-medium">0</span></li>
                  <li><span class="dot dot-green"></span> Baja: <span class="issues-prio-low">0</span></li>
                </ul>
              </div>
            </div>
            <div class="analytics--chart card-issues-status">
              <div class="chart--title">Issues abiertos vs resueltos</div>
              <div class="bars">
                <div class="barwrap"><div class="bar bar-open" style="width:0%"></div></div>
                <div class="barwrap"><div class="bar bar-closed" style="width:0%"></div></div>
              </div>
              <div class="bars--labels">
                <span>Abiertos: <strong class="issues-open-count">0</strong></span>
                <span>Resueltos: <strong class="issues-closed-count">0</strong></span>
              </div>
            </div>
          </div>
          <div class="analytics--sep" style="height:12px"></div>
          <div class="analytics--row">
            <div class="analytics--chart card-rocks-status">
              <div class="chart--title">Rocas por estado</div>
              <div class="chart--wrap">
                <div class="pie pie-rocks-status" aria-label="Rocas por estado"></div>
                <ul class="chart--legend">
                  <li><span class="dot dot-green"></span> Completadas: <span class="rocks-done-count">0</span></li>
                  <li><span class="dot dot-blue"></span> En progreso: <span class="rocks-inprogress-count">0</span></li>
                  <li><span class="dot dot-red"></span> Vencidas: <span class="rocks-overdue-count">0</span></li>
                </ul>
              </div>
            </div>
            <div class="analytics--chart card-rocks-kpis">
              <div class="chart--title">Resumen de Rocas</div>
              <ul class="chart--legend">
                <li>Total: <strong class="rocks-total-count">0</strong></li>
                <li>Promedio de progreso: <strong class="rocks-avg-progress">0%</strong></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Columna derecha: Rocks y Chart apilados -->
        <div class="mi90--rightcol">
          <div class="mi90--card mi90--rocks">
            <t t-call="mi90_eos.Rocks"/>
          </div>
          <div class="mi90--card mi90--chart">
            <h2>Estado de Objetivos</h2>
            <div class="chart--wrap">
              <div class="pie" aria-label="Estados de L10"></div>
              <div class="chart--info">
                <div class="chart--total"><span class="chart--total-num">0</span> <span>Total</span></div>
                <ul class="chart--legend">
                  <li><span class="dot dot-green"></span> <span class="chart--count-done">0</span> Completada - <span class="chart--pct-done">0%</span></li>
                  <li><span class="dot dot-blue"></span> <span class="chart--count-inprogress">0</span> En curso - <span class="chart--pct-inprogress">0%</span></li>
                  <li><span class="dot dot-red"></span> <span class="chart--count-overdue">0</span> Fuera de curso - <span class="chart--pct-overdue">0%</span></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </t>
</templates>