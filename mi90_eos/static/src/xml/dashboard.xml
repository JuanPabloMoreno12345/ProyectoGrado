<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
  <t t-name="mi90_eos.Dashboard">
    <div class="mi90--wrap" t-ref="root">
      <div class="mi90--header">
        <h1>EOS DATA</h1>
        <div class="mi90--nav-buttons">
          <button class="mi90--nav-btn active" data-view="mi90">Mi 90</button>
          <button class="mi90--nav-btn" data-view="scorecard">Scorecard</button>
        </div>
        <div class="mi90--legend">
          <span class="dot dot-lav"></span> Lavanda
          <span class="dot dot-cel"></span> Celeste
          <span class="dot dot-ros"></span> Rosa
        </div>
      </div>

      <div class="mi90--grid">
        <div class="mi90--card mi90--scorecard">
          <h2>Panel de Control</h2>
          <div class="scorecard--toolbar">
            <div class="tabs">
              <span class="tab active">Semanal</span>
              <span class="tab">Mensual</span>
              <span class="tab">Trimestral</span>
              <span class="tab">Anual</span>
            </div>
          </div>
          <table class="scorecard--table">
            <thead>
              <tr>
                <th>Métrica</th>
                <th>Meta</th>
                <th>Actual</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span class="dot dot-green"></span>Conversaciones significativas</td>
                <td>≥ 25</td>
                <td>16.2</td>
                <td><span class="dot dot-red"></span></td>
              </tr>
              <tr>
                <td><span class="dot dot-blue"></span>Nuevos clientes</td>
                <td>≥ 0.25</td>
                <td>0.8</td>
                <td><span class="dot dot-green"></span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mi90--row">
          <div class="mi90--card mi90--todos">
            <h2>Tareas del equipo <span class="badge">3</span></h2>
            <div class="todos--item">
              <input type="checkbox" />
              <span>Problema 5</span>
              <span class="todos--tag">Hoy</span>
            </div>
            <div class="todos--item">
              <input type="checkbox" />
              <span>To-Do #2</span>
              <span class="todos--tag">Hoy</span>
            </div>
            <div class="todos--item">
              <input type="checkbox" />
              <span>To-Do #4</span>
              <span class="todos--tag">Hoy</span>
            </div>
          </div>

          <div class="mi90--card mi90--rocks">
            <h2>Objetivos y Metas</h2>
            <div class="rocks--item">
              <div>✅ Asegurar 3 nuevos clientes</div>
              <div class="rocks--progress">
                <div class="rocks--progress-bar" style="width: 100%"></div>
              </div>
              <div class="rocks--meta">
                <span>Completado</span>
                <span>31 Mar</span>
              </div>
            </div>
            <div class="rocks--item">
              <div>👍 Roca #2</div>
              <div class="rocks--progress">
                <div class="rocks--progress-bar" style="width: 67%"></div>
              </div>
              <div class="rocks--meta">
                <span>En progreso</span>
                <span>31 Mar</span>
              </div>
            </div>
          </div>

          <div class="mi90--card mi90--chart">
            <h2>Estado de Objetivos</h2>
            <div class="chart--wrap">
              <div class="pie" aria-label="Estados de rocas"></div>
              <div class="chart--info">
                <div class="chart--total">3 <span>Total</span></div>
                <ul class="chart--legend">
                  <li><span class="dot dot-green"></span> 1 Completada - 33%</li>
                  <li><span class="dot dot-blue"></span> 2 En curso - 67%</li>
                  <li><span class="dot dot-red"></span> 0 Fuera de curso - 0%</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </t>
</templates>