<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
  <t t-name="mi90_eos.Scorecard">
    <div class="scorecard--wrap">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <div style="font-weight:700">Scorecard - Rendimiento del Equipo</div>
        <div class="sc-last-update" style="font-size:12px;color:var(--muted)">—</div>
      </div>
      <div class="scorecard--toolbar">
        <div class="tabs">
          <span class="tab active">Semanal</span>
          <span class="tab">Mensual</span>
          <span class="tab">Trimestral</span>
          <span class="tab">Anual</span>
        </div>
        <div class="filters">
          <label>Equipo</label>
          <select disabled="disabled">
            <option>Mi Equipo</option>
          </select>
        </div>
      </div>
      <table class="scorecard--table">
        <thead>
          <tr class="sc-head">
            <th class="sc-sticky">Owner</th>
            <th class="sc-sticky">Measurable</th>
            <th class="sc-sticky">Weekly Goal</th>
            <!-- Semanas dinámicas -->
          </tr>
        </thead>
        <tbody class="scorecard-body"><!-- filas dinámicas --></tbody>
      </table>
    </div>
  </t>
</templates>
