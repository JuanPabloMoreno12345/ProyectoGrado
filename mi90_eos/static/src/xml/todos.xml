<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
  <t t-name="mi90_eos.Todos">
    <div class="todos--wrap">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <div style="font-weight:700">To-Do Board</div>
        <div style="display:flex;gap:8px;align-items:center">
          <input class="mi90-todo-new-input" type="text" placeholder="Agregar actividad..." style="padding:6px;border-radius:8px;border:1px solid #e6e6e6"/>
          <button class="mi90-todo-add-btn mi90--nav-btn" style="padding:6px 10px">Agregar</button>
        </div>
      </div>

      <div class="todos-board" style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px">
        <div class="todos-column" data-state="todo">
          <div style="font-weight:700;margin-bottom:8px">POR HACER <span class="badge mi90-todos-count-todo">0</span></div>
          <div class="todos-column-list"></div>
        </div>
        <div class="todos-column" data-state="in_progress">
          <div style="font-weight:700;margin-bottom:8px">EN CURSO <span class="badge mi90-todos-count-in_progress">0</span></div>
          <div class="todos-column-list"></div>
        </div>
        <div class="todos-column" data-state="in_review">
          <div style="font-weight:700;margin-bottom:8px">EN REVISIÓN <span class="badge mi90-todos-count-in_review">0</span></div>
          <div class="todos-column-list"></div>
        </div>
        <div class="todos-column" data-state="done">
          <div style="font-weight:700;margin-bottom:8px">FINALIZADO <span class="badge mi90-todos-count-done">0</span></div>
          <div class="todos-column-list"></div>
        </div>
      </div>
    </div>
  </t>
</templates>
