<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_meeting_tree" model="ir.ui.view">
    <field name="name">eos.meeting.tree</field>
    <field name="model">eos.meeting</field>
    <field name="arch" type="xml">
      <tree string="Meetings">
        <field name="name"/>
        <field name="date"/>
        <field name="attendees"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_meeting_form" model="ir.ui.view">
    <field name="name">eos.meeting.form</field>
    <field name="model">eos.meeting</field>
    <field name="arch" type="xml">
      <form string="Meeting">
        <sheet>
          <header>
            <button class="oe_stat_button" type="object" name="action_view_todos"
                    icon="fa-check-square-o">
              <field name="todo_count" widget="statinfo" string="To-Dos"/>
            </button>
          </header>
          <group>
            <field name="name"/>
            <field name="date"/>
            <field name="attendees"/>
          </group>
          <group string="Roles L10">
            <field name="integrator_id"/>
            <field name="time_keeper_id"/>
          </group>
          <group string="Checklist previa">
            <field name="precheck_scorecard"/>
            <field name="precheck_rocks"/>
            <field name="precheck_todos"/>
          </group>
          <group>
            <field name="score"/>
          </group>
          <notebook>
            <page string="Notas">
              <field name="notes" nolabel="1"/>
            </page>
            <page string="Decisiones">
              <field name="decisions" nolabel="1"/>
            </page>
            <page string="To-Dos">
              <field name="todo_ids" context="{'default_meeting_id': active_id}">
                <tree editable="bottom">
                  <field name="name"/>
                  <field name="owner_id"/>
                  <field name="due_date"/>
                  <field name="status"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eos_meeting" model="ir.actions.act_window">
    <field name="name">Meetings</field>
    <field name="res_model">eos.meeting</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_eos_meeting" name="Meetings" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_meeting"/>
</odoo>
