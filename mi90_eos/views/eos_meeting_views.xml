<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_meeting_tree" model="ir.ui.view">
    <field name="name">eos.meeting.tree</field>
    <field name="model">eos.meeting</field>
    <field name="arch" type="xml">
      <tree string="Meetings">
        <field name="name"/>
        <field name="date"/>
        <field name="attendees"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_meeting_form" model="ir.ui.view">
    <field name="name">eos.meeting.form</field>
    <field name="model">eos.meeting</field>
    <field name="arch" type="xml">
      <form string="Meeting">
        <sheet>
          <group>
            <field name="name"/>
            <field name="date"/>
            <field name="attendees"/>
          </group>
          <group>
            <field name="notes"/>
            <field name="decisions"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eos_meeting" model="ir.actions.act_window">
    <field name="name">Meetings</field>
    <field name="res_model">eos.meeting</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_eos_meeting" name="Meetings" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_meeting"/>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
  <t t-name="mi90_eos.Meetings">
    <div class="meetings--wrap">
      <ul class="meetings--list">
        <li class="meeting">
          <div class="meeting--title">Weekly L10 — Equipo Comercial</div>
          <div class="meeting--meta">Fecha: 25 Mar · Estado: Confirmada</div>
        </li>
        <li class="meeting">
          <div class="meeting--title">Weekly L10 — Dirección</div>
          <div class="meeting--meta">Fecha: 26 Mar · Estado: Reprogramada</div>
        </li>
      </ul>
    </div>
  </t>
</templates>
