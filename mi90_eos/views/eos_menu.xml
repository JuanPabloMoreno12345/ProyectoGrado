<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client action that launches the OWL dashboard frontend -->
    <record id="mi90_eos.action_mi90_dashboard" model="ir.actions.client">
        <field name="name">Mi90 Dashboard</field>
        <field name="tag">mi90_eos.dashboard_action</field>
        <field name="target">current</field>
    </record>

    <!-- Root menu for the module -->
    <menuitem id="mi90_eos.menu_root" name="EOS" sequence="90"/>

    <!-- Dashboard menu linking to the client action -->
    <menuitem id="mi90_eos.menu_dashboard"
              name="Mi90 Dashboard"
              parent="mi90_eos.menu_root"
              action="mi90_eos.action_mi90_dashboard"
              sequence="10"/>
</odoo>
