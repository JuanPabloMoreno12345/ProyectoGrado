<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_kpi_tree" model="ir.ui.view">
    <field name="name">eos.kpi.tree</field>
    <field name="model">eos.kpi</field>
    <field name="arch" type="xml">
      <tree string="Scorecard Metrics">
        <field name="name"/>
        <field name="unit"/>
        <field name="target"/>
        <field name="owner_id"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_kpi_form" model="ir.ui.view">
    <field name="name">eos.kpi.form</field>
    <field name="model">eos.kpi</field>
    <field name="arch" type="xml">
      <form string="KPI">
        <sheet>
          <group>
            <field name="name"/>
            <field name="unit"/>
            <field name="target"/>
            <field name="owner_id"/>
          </group>
          <notebook>
            <page string="Values">
              <field name="value_ids">
                <tree>
                  <field name="date"/>
                  <field name="value"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eos_kpi" model="ir.actions.act_window">
    <field name="name">Scorecard</field>
    <field name="res_model">eos.kpi</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_eos_kpi" name="Scorecard" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_kpi"/>
</odoo>
