<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_rock_tree" model="ir.ui.view">
    <field name="name">eos.rock.tree</field>
    <field name="model">eos.rock</field>
    <field name="arch" type="xml">
      <tree string="Rocks">
        <field name="name"/>
        <field name="owner_id"/>
        <field name="due_date"/>
        <field name="progress"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_rock_form" model="ir.ui.view">
    <field name="name">eos.rock.form</field>
    <field name="model">eos.rock</field>
    <field name="arch" type="xml">
      <form string="Rock">
        <sheet>
          <group>
            <field name="name"/>
            <field name="owner_id"/>
            <field name="due_date"/>
            <field name="status"/>
            <field name="progress"/>
          </group>
          <notebook>
            <page string="Key Results">
              <field name="key_result_ids">
                <tree editable="bottom">
                  <field name="name"/>
                  <field name="current_value"/>
                  <field name="target_value"/>
                  <field name="weight"/>
                </tree>
              </field>
            </page>
            <page string="Todos">
              <field name="key_result_ids"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eos_rock" model="ir.actions.act_window">
    <field name="name">Rocks</field>
    <field name="res_model">eos.rock</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_mi90_root_models" name="ROCAS" parent="mi90_eos.menu_root"/>
  <menuitem id="menu_eos_rock" name="Rocks" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_rock"/>

</odoo>
