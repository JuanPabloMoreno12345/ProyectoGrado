<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_todo_tree" model="ir.ui.view">
    <field name="name">eos.todo.tree</field>
    <field name="model">eos.todo</field>
    <field name="arch" type="xml">
      <tree string="To-Dos">
        <field name="name"/>
        <field name="owner_id"/>
        <field name="due_date"/>
        <field name="progress"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_todo_form" model="ir.ui.view">
    <field name="name">eos.todo.form</field>
    <field name="model">eos.todo</field>
    <field name="arch" type="xml">
      <form string="To-Do">
        <sheet>
          <group>
            <field name="name"/>
            <field name="owner_id"/>
            <field name="due_date"/>
            <field name="status"/>
            <field name="progress"/>
            <field name="rock_id"/>
          </group>
          <group>
            <field name="description" placeholder="Description..."/>
          </group>
          <group>
            <field name="date_create"/>
            <field name="date_update"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eos_todo" model="ir.actions.act_window">
    <field name="name">To-Do</field>
    <field name="res_model">eos.todo</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_eos_todo" name="To-Do" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_todo" sequence="2"/>

</odoo>
