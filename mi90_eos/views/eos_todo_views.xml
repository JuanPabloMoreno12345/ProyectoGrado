<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_todo_tree" model="ir.ui.view">
    <field name="name">eos.todo.tree</field>
    <field name="model">eos.todo</field>
    <field name="arch" type="xml">
      <tree string="To-Dos">
        <field name="name"/>
        <field name="assigned_to"/>
        <field name="due_date"/>
        <field name="done"/>
        <field name="rock_id"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_todo_form" model="ir.ui.view">
    <field name="name">eos.todo.form</field>
    <field name="model">eos.todo</field>
    <field name="arch" type="xml">
      <form string="To-Do">
        <sheet>
          <group>
            <field name="name"/>
            <field name="assigned_to"/>
            <field name="due_date"/>
            <field name="done"/>
            <field name="rock_id"/>
            <field name="note"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eos_todo" model="ir.actions.act_window">
    <field name="name">To-Dos</field>
    <field name="res_model">eos.todo</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_eos_todo" name="To-Dos" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_todo"/>
</odoo>
