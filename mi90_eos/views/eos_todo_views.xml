<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_todo_tree" model="ir.ui.view">
    <field name="name">eos.todo.tree</field>
    <field name="model">eos.todo</field>
    <field name="arch" type="xml">
      <tree string="To-Dos" decoration-success="status=='done'" decoration-warning="status=='in_review'" decoration-info="status=='in_progress'">
        <field name="name"/>
        <field name="owner_id"/>
        <field name="due_date"/>
        <field name="status"/>
        <field name="progress" widget="progressbar"/>
        <field name="date_create"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_todo_form" model="ir.ui.view">
    <field name="name">eos.todo.form</field>
    <field name="model">eos.todo</field>
    <field name="arch" type="xml">
      <form string="To-Do">
        <header>
          <button name="action_start_progress" type="object" string="Iniciar" class="btn-primary" 
                  invisible="status != 'todo'"/>
          <button name="action_mark_for_review" type="object" string="Marcar para Revisión" class="btn-warning" 
                  invisible="status != 'in_progress'"/>
          <button name="action_mark_done" type="object" string="Completar" class="btn-success" 
                  invisible="status not in ('in_progress', 'in_review')"/>
          <button name="action_reset_to_todo" type="object" string="Reiniciar" class="btn-secondary" 
                  invisible="status in ('todo', 'cancel')"/>
          <field name="status" widget="statusbar" statusbar_visible="todo,in_progress,in_review,done"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Nombre de la tarea..." required="1"/>
            </h1>
          </div>
          <group>
            <group>
              <field name="owner_id" options="{'no_create': True}"/>
              <field name="due_date"/>
              <field name="rock_id" options="{'no_create': True}"/>
            </group>
            <group>
              <field name="progress" widget="progressbar"/>
              <field name="date_create" readonly="1"/>
              <field name="date_update" readonly="1"/>
            </group>
          </group>
          <notebook>
            <page string="Descripción">
              <field name="description" placeholder="Descripción de la tarea..." nolabel="1"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_eos_todo_search" model="ir.ui.view">
    <field name="name">eos.todo.search</field>
    <field name="model">eos.todo</field>
    <field name="arch" type="xml">
      <search string="Buscar To-Dos">
  <field name="name" string="Nombre"/>
        <field name="owner_id" string="Asignado a"/>
        <field name="status" string="Estado"/>
        <separator/>
        <filter name="my_todos" string="Mis Tareas" domain="[('owner_id', '=', uid)]"/>
        <filter name="pending" string="Pendientes" domain="[('status', '!=', 'done')]"/>
        <filter name="completed" string="Completadas" domain="[('status', '=', 'done')]"/>
  <filter name="overdue" string="Vencidas" domain="[('due_date', '&lt;', context_today()), ('status', '!=', 'done')]"/>
        <separator/>
        <group expand="0" string="Agrupar por">
          <filter name="group_status" string="Estado" context="{'group_by': 'status'}"/>
          <filter name="group_owner" string="Asignado a" context="{'group_by': 'owner_id'}"/>
          <filter name="group_due_date" string="Fecha de Vencimiento" context="{'group_by': 'due_date'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_eos_todo" model="ir.actions.act_window">
    <field name="name">To-Do</field>
    <field name="res_model">eos.todo</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_eos_todo_search"/>
    <field name="context">{'search_default_pending': 1}</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        ¡Crea tu primera tarea!
      </p>
      <p>
        Las tareas te ayudan a organizar y dar seguimiento a tu trabajo.
        Puedes asignarlas a miembros del equipo y relacionarlas con Rocks.
      </p>
    </field>
  </record>

  <!-- Acción cliente dedicada al tablero To-Do -->
  <record id="action_eos_todo_board" model="ir.actions.client">
    <field name="name">To-Do Board</field>
    <field name="tag">mi90_eos.todo_board</field>
    <field name="target">current</field>
  </record>

  <!-- Link del menú To-Do hacia la nueva acción cliente que muestra solo el tablero -->
  <menuitem id="menu_eos_todo" name="To-Do" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_todo_board" sequence="2"/>

</odoo>
