<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_issue_tree" model="ir.ui.view">
    <field name="name">eos.issue.tree</field>
    <field name="model">eos.issue</field>
    <field name="arch" type="xml">
      <tree string="Issues">
        <field name="name"/>
        <field name="priority"/>
        <field name="owner_id"/>
        <field name="resolved"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_issue_form" model="ir.ui.view">
    <field name="name">eos.issue.form</field>
    <field name="model">eos.issue</field>
    <field name="arch" type="xml">
      <form string="Issue">
        <sheet>
          <group>
            <field name="name"/>
            <field name="priority"/>
            <field name="owner_id"/>
            <field name="resolved"/>
            <field name="description"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eos_issue" model="ir.actions.act_window">
    <field name="name">Issues</field>
    <field name="res_model">eos.issue</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_eos_issue" name="Issues" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_issue"/>
</odoo>
