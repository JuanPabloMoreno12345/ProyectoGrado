<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
  <t t-name="mi90_eos.Dashboard">
    <div class="mi90--wrap">
      <div class="mi90--header">
        <h1>EOS DATA</h1>
        <div class="mi90--legend">
          <span class="dot dot-lav"></span> Lavanda
          <span class="dot dot-cel"></span> Celeste
          <span class="dot dot-ros"></span> Rosa
        </div>
      </div>

      <div class="mi90--grid">
        <div class="mi90--card mi90--scorecard">
          <h2>Scorecard</h2>
          <t t-call="mi90_eos.Scorecard"/>
        </div>

        <div class="mi90--card mi90--rocks">
          <h2>L10</h2>
          <t t-call="mi90_eos.Rocks"/>
        </div>

        <div class="mi90--card mi90--todos">
          <h2>To-Dos</h2>
          <t t-call="mi90_eos.Todos"/>
        </div>

        <div class="mi90--card mi90--issues">
          <h2>Problemas</h2>
          <t t-call="mi90_eos.Issues"/>
        </div>

        <div class="mi90--card mi90--meetings">
          <h2>Reuniones (L10)</h2>
          <t t-call="mi90_eos.Meetings"/>
        </div>
      </div>
    </div>
  </t>
</templates>
