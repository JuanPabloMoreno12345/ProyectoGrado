<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_eos_key_result_tree" model="ir.ui.view">
    <field name="name">eos.key_result.tree</field>
    <field name="model">eos.key_result</field>
    <field name="arch" type="xml">
      <tree string="Key Results">
        <field name="name"/>
        <field name="rock_id"/>
        <field name="current_value"/>
        <field name="target_value"/>
        <field name="weight"/>
        <field name="status"/>
      </tree>
    </field>
  </record>

  <record id="view_eos_key_result_form" model="ir.ui.view">
    <field name="name">eos.key_result.form</field>
    <field name="model">eos.key_result</field>
    <field name="arch" type="xml">
      <form string="Key Result">
        <sheet>
          <group>
            <field name="name"/>
            <field name="rock_id"/>
            <field name="current_value"/>
            <field name="target_value"/>
            <field name="kr_type"/>
            <field name="weight"/>
            <field name="status"/>
            <field name="note"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eos_key_result" model="ir.actions.act_window">
    <field name="name">Key Results</field>
    <field name="res_model">eos.key_result</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_eos_key_result" name="Key Results" parent="mi90_eos.menu_mi90_root_models" action="mi90_eos.action_eos_key_result"/>
</odoo>
